package com.student.gamez;

import javax.swing.*;
import javax.swing.Timer;          // explicit import to avoid conflict with java.util.Timer
import java.awt.*;
import java.awt.event.*;
import java.awt.geom.Path2D;
import java.util.ArrayList;
import java.util.HashMap;
import java.util.List;
import java.util.Map;
import java.util.Random;


public class SnakesAndLadder extends JFrame {

    private final BoardPanel boardPanel;
    private final JButton rollButton;
    private final JLabel statusLabel;
    private final DicePanel dicePanel;

    private final List<String> playerNames;
    private final Map<String, Integer> positions;
    private final Map<Integer, Integer> snakes;
    private final Map<Integer, Integer> ladders;

    private int currentPlayerIndex = 0;
    private final Random random = new Random();

    // Animation fields
    private final Timer moveTimer;
    private int movingPlayerIndex = -1;
    private int animatedPos = 0;
    private int moveTarget = 0;


    public SnakesAndLadder() {
        setTitle("Snakes and Ladders");
        setDefaultCloseOperation(JFrame.EXIT_ON_CLOSE);
        setSize(820, 780);
        setLocationRelativeTo(null);
        setLayout(new BorderLayout());
        
     
        // Game data
        snakes = new HashMap<>();
        ladders = new HashMap<>();
        initSnakesAndLadders();

        playerNames = new ArrayList<>();
        playerNames.add("Red");
        playerNames.add("Blue");

        positions = new HashMap<>();
        for (String name : playerNames) {
            positions.put(name, 0);
        }

        // Main board
        boardPanel = new BoardPanel();
        add(boardPanel, BorderLayout.CENTER);

        // Control panel
        JPanel controlPanel = new JPanel(new FlowLayout(FlowLayout.CENTER, 20, 10));
        statusLabel = new JLabel("Red's turn", SwingConstants.CENTER);
        statusLabel.setFont(new Font("Arial", Font.BOLD, 20));

        rollButton = new JButton("ROLL DICE");
        rollButton.setFont(new Font("Arial", Font.BOLD, 18));
        rollButton.setBackground(new Color(255, 120, 255));
        rollButton.setForeground(Color.WHITE);

        dicePanel = new DicePanel();

        rollButton.addActionListener(new RollListener());

        controlPanel.add(statusLabel);
        controlPanel.add(dicePanel);
        controlPanel.add(rollButton);

        add(controlPanel, BorderLayout.SOUTH);

        moveTimer = new Timer(80, e -> animateMovementStep());
        moveTimer.setRepeats(true);

        updateStatus();
    }

    private void initSnakesAndLadders() {
         // Snakes (head -> tail)
        snakes.put(16, 6);  snakes.put(47, 26); snakes.put(49, 11);
        snakes.put(56, 53); snakes.put(62, 19); snakes.put(64, 60);
        snakes.put(87, 24); snakes.put(93, 73); snakes.put(95, 75);
        snakes.put(98, 78);

        // Ladders (bottom -> top)
        ladders.put(1, 38); ladders.put(4, 14);  ladders.put(9, 31);
        ladders.put(21, 42); ladders.put(28, 84); ladders.put(36, 44);
        ladders.put(51, 67); ladders.put(71, 91); ladders.put(80, 100);
    }

    private void updateStatus() {
        String current = playerNames.get(currentPlayerIndex);
        statusLabel.setText(current + "'s turn  |  Position: " + positions.get(current));
        boardPanel.repaint();
    }

    // ==================== ROLL & MOVEMENT LOGIC ====================

    private class RollListener implements ActionListener {
        @Override
        public void actionPerformed(ActionEvent e) {
            rollButton.setEnabled(false);
            int roll = random.nextInt(6) + 1;
            dicePanel.rollTo(roll, () -> proceedWithMove(roll));
        }
    }

    private void proceedWithMove(int roll) {
        String currentPlayer = playerNames.get(currentPlayerIndex);
        int currentPos = positions.get(currentPlayer);
        int tempPos = currentPos + roll;

        if (tempPos > 100) {
            tempPos = currentPos; // stay put if overshoot
        }

        movingPlayerIndex = currentPlayerIndex;
        animatedPos = currentPos;
        moveTarget = tempPos;

        moveTimer.start();
    }

    private void animateMovementStep() {
        if (movingPlayerIndex == -1) return;

        if (animatedPos < moveTarget) {
            animatedPos++;
            boardPanel.repaint();
        } else {
            moveTimer.stop();
            finishMove();
        }
    }

    private void finishMove() {
        String currentPlayer = playerNames.get(currentPlayerIndex);
        int landedPos = moveTarget;
        int finalPos = landedPos;
        String specialMessage = null;

        if (snakes.containsKey(landedPos)) {
            finalPos = snakes.get(landedPos);
            specialMessage = "Snake! Slid down to " + finalPos;
        } else if (ladders.containsKey(landedPos)) {
            finalPos = ladders.get(landedPos);
            specialMessage = "Ladder! Climbed up to " + finalPos;
        }

        positions.put(currentPlayer, finalPos);
        boardPanel.repaint();

        if (specialMessage != null) {
            JOptionPane.showMessageDialog(this, specialMessage,
                    "Special Move!", JOptionPane.INFORMATION_MESSAGE);
        }

        if (finalPos == 100) {
            JOptionPane.showMessageDialog(this,
                    currentPlayer + " WINS THE GAME!",
                    "Game Over", JOptionPane.INFORMATION_MESSAGE);
            System.exit(0);
        }

        movingPlayerIndex = -1;
        currentPlayerIndex = (currentPlayerIndex + 1) % playerNames.size();
        updateStatus();
        Toolkit.getDefaultToolkit().beep(); //GIVES US THE BEEP SOUND WHEN A PLAYER REACHES A TARGET POSITION
        rollButton.setEnabled(true);
    }

    // ==================== BOARD PANEL ====================

    private class BoardPanel extends JPanel {
        private final int SIZE = 10;
        private final int CELL_SIZE = 60;

        public BoardPanel() {
            setPreferredSize(new Dimension(SIZE * CELL_SIZE + 20, SIZE * CELL_SIZE + 20));
            setBackground(new Color(255, 248, 220));
        }

        @Override
        protected void paintComponent(Graphics g) {
            super.paintComponent(g);
            Graphics2D g2d = (Graphics2D) g;
            g2d.setRenderingHint(RenderingHints.KEY_ANTIALIASING, RenderingHints.VALUE_ANTIALIAS_ON);

            // Draw the 10x10 board with zigzag numbering
            for (int row = 0; row < SIZE; row++) {
                for (int col = 0; col < SIZE; col++) {
                    int square = getSquareNumber(row, col);
                    int x = col * CELL_SIZE + 10;
                    int y = row * CELL_SIZE + 10;

                    g2d.setColor((row + col) % 2 == 0 ? new Color(230, 245, 255) : new Color(255, 255, 230));
                    g2d.fillRect(x, y, CELL_SIZE, CELL_SIZE);
                    g2d.setColor(new Color(100, 100, 100));
                    g2d.drawRect(x, y, CELL_SIZE, CELL_SIZE);

                    g2d.setFont(new Font("Arial", Font.BOLD, 13));
                    FontMetrics fm = g2d.getFontMetrics();
                    String numStr = String.valueOf(square);
                    int tx = x + CELL_SIZE - fm.stringWidth(numStr) - 5;
                    int ty = y + CELL_SIZE - 6;
                    g2d.setColor(Color.BLACK);
                    g2d.drawString(numStr, tx, ty);
                }
            }

            // Draw ladders
            g2d.setStroke(new BasicStroke(4));
            for (Map.Entry<Integer, Integer> entry : ladders.entrySet()) {
                Point p1 = getPositionCoordinates(entry.getKey());
                Point p2 = getPositionCoordinates(entry.getValue());
                drawLadder(g2d, p1, p2);
            }

            // Draw snakes
            g2d.setStroke(new BasicStroke(4));
            for (Map.Entry<Integer, Integer> entry : snakes.entrySet()) {
                Point p1 = getPositionCoordinates(entry.getKey());
                Point p2 = getPositionCoordinates(entry.getValue());
                drawSnake(g2d, p1, p2);
            }

            // Draw player tokens
            Color[] colors = {Color.RED, Color.BLUE, Color.GREEN, Color.ORANGE};
            int playerOffset = 0;
            for (int i = 0; i < playerNames.size(); i++) {
                int displayPos = (i == movingPlayerIndex) ? animatedPos : positions.get(playerNames.get(i));
                if (displayPos == 0) continue;

                Point p = getPositionCoordinates(displayPos);
                Color playerColor = colors[i % colors.length];

                // Shadow
                g2d.setColor(new Color(0, 0, 0, 80));
                g2d.fillOval(p.x - 16 + playerOffset, p.y - 12, 28, 28);

                // Token
                g2d.setColor(playerColor);
                g2d.fillOval(p.x - 14 + playerOffset, p.y - 14, 28, 28);

                // White border
                g2d.setColor(Color.WHITE);
                g2d.setStroke(new BasicStroke(3));
                g2d.drawOval(p.x - 14 + playerOffset, p.y - 14, 28, 28);

                // Player number label
                g2d.setFont(new Font("Arial", Font.BOLD, 14));
                g2d.setColor(Color.BLACK);
                g2d.drawString(String.valueOf(i + 1), p.x - 5 + playerOffset, p.y + 5);

                playerOffset += 6;
            }
        }

        
        private int getSquareNumber(int row, int col) {
            int boardRow = SIZE - 1 - row; // 0 = bottom row
            int base = boardRow * SIZE + 1;
            if (boardRow % 2 == 0) {
                return base + col;          // left to right
            } else {
                return base + (SIZE - 1 - col); // right to left
            }
        }

    
        private Point getPositionCoordinates(int square) {
            if (square <= 0) return new Point(10 + CELL_SIZE / 2, 10 + (SIZE - 1) * CELL_SIZE + CELL_SIZE / 2);
            int boardRow = (square - 1) / SIZE;          // 0 = bottom
            int col     = (square - 1) % SIZE;
            if (boardRow % 2 != 0) {
                col = SIZE - 1 - col;                     // right-to-left on odd board rows
            }
            int visualRow = SIZE - 1 - boardRow;          // convert back to screen row (0 = top)
            int x = col * CELL_SIZE + CELL_SIZE / 2 + 10;
            int y = visualRow * CELL_SIZE + CELL_SIZE / 2 + 10;
            return new Point(x, y);
        }

        private void drawLadder(Graphics2D g2d, Point p1, Point p2) {
            double dx = p2.x - p1.x;
            double dy = p2.y - p1.y;
            double len = Math.hypot(dx, dy);
            if (len == 0) return;

            double ux = dx / len;
            double uy = dy / len;
            double px = -uy * 8;
            double py = ux * 8;

            g2d.setColor(new Color(139, 69, 19));
            g2d.drawLine((int)(p1.x + px), (int)(p1.y + py), (int)(p2.x + px), (int)(p2.y + py));
            g2d.drawLine((int)(p1.x - px), (int)(p1.y - py), (int)(p2.x - px), (int)(p2.y - py));

            g2d.setColor(new Color(205, 133, 63));
            int numRungs = Math.max(4, (int)(len / 25));
            for (int i = 1; i < numRungs; i++) {
                double t = i / (double) numRungs;
                int rx1 = (int)(p1.x + t * dx + px);
                int ry1 = (int)(p1.y + t * dy + py);
                int rx2 = (int)(p1.x + t * dx - px);
                int ry2 = (int)(p1.y + t * dy - py);
                g2d.drawLine(rx1, ry1, rx2, ry2);
            }
        }

        private void drawSnake(Graphics2D g2d, Point p1, Point p2) {
            Path2D path = new Path2D.Double();
            path.moveTo(p1.x, p1.y);

            double dx = p2.x - p1.x;
            double dy = p2.y - p1.y;
            double len = Math.hypot(dx, dy);
            if (len == 0) return;

            double ux = dx / len;
            double uy = dy / len;
            double px = -uy;
            double py = ux;

            int steps = 28;
            double amplitude = 11.0;

            for (int i = 1; i <= steps; i++) {
                double t = i / (double) steps;
                double baseX = p1.x + t * dx;
                double baseY = p1.y + t * dy;
                double wave = amplitude * Math.sin(t * Math.PI * 5.5);
                path.lineTo(baseX + wave * px, baseY + wave * py);
            }
            path.lineTo(p2.x, p2.y);

            // Red body
            g2d.setColor(new Color(200, 20, 20));
            g2d.setStroke(new BasicStroke(11, BasicStroke.CAP_ROUND, BasicStroke.JOIN_ROUND));
            g2d.draw(path);

            // Black outline
            g2d.setColor(Color.BLACK);
            g2d.setStroke(new BasicStroke(3, BasicStroke.CAP_ROUND, BasicStroke.JOIN_ROUND));
            g2d.draw(path);
        }
    }

    // ==================== DICE PANEL ====================

    private class DicePanel extends JPanel {
        private int currentFace = 1;

        public DicePanel() {
            setPreferredSize(new Dimension(90, 90));
            setBackground(Color.WHITE);
        }

        public void rollTo(int finalFace, Runnable onComplete) {
            // Use array holder so the lambda can stop the timer without a cast
            Timer[] holder = new Timer[1];
            int[] count = {0};
            holder[0] = new Timer(65, e -> {
                currentFace = random.nextInt(6) + 1;
                repaint();
                count[0]++;
                if (count[0] >= 14) {
                    holder[0].stop();   // direct reference — no ambiguous cast needed
                    currentFace = finalFace;
                    repaint();
                    if (onComplete != null) onComplete.run();
                }
            });
            holder[0].start();
        }

        @Override
        protected void paintComponent(Graphics g) {
            super.paintComponent(g);
            Graphics2D g2d = (Graphics2D) g;
            g2d.setRenderingHint(RenderingHints.KEY_ANTIALIASING, RenderingHints.VALUE_ANTIALIAS_ON);

            g2d.setColor(new Color(255, 230, 180));
            g2d.fillRoundRect(8, 8, 74, 74, 18, 18);
            g2d.setColor(Color.BLACK);
            g2d.setStroke(new BasicStroke(3));
            g2d.drawRoundRect(8, 8, 74, 74, 18, 18);

            g2d.setColor(Color.BLACK);
            int[][] dotPos = getDotPositions(currentFace);
            for (int[] p : dotPos) {
                g2d.fillOval(p[0] - 7, p[1] - 7, 14, 14);
            }
        }

        private int[][] getDotPositions(int face) {
            int c = 45, o = 22;
            return switch (face) {
                case 1 -> new int[][]{{c, c}};
                case 2 -> new int[][]{{o, o}, {c + o - 4, c + o - 4}};
                case 3 -> new int[][]{{o, o}, {c, c}, {c + o - 4, c + o - 4}};
                case 4 -> new int[][]{{o, o}, {o, c + o - 4}, {c + o - 4, o}, {c + o - 4, c + o - 4}};
                case 5 -> new int[][]{{o, o}, {o, c + o - 4}, {c + o - 4, o}, {c + o - 4, c + o - 4}, {c, c}};
                case 6 -> new int[][]{{o, o}, {o, c}, {o, c + o - 4}, {c + o - 4, o}, {c + o - 4, c}, {c + o - 4, c + o - 4}};
                default -> new int[0][0];
            };
        }
    }

    // ==================== MAIN ====================

    // BUG FIX 6: main() now correctly instantiates SnakesAndLadder (no-arg constructor).
    public static void main(String[] args) {
        SwingUtilities.invokeLater(() -> new SnakesAndLadder().setVisible(true));
    }
}
